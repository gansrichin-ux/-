rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/adminAccounts/$(request.auth.uid))
        && get(/databases/$(database)/documents/adminAccounts/$(request.auth.uid)).data.active == true;
    }

    function hasCurrentUserRole(role) {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role
          || (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles is list
            && role in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles));
    }

    function isLogistician() {
      return hasCurrentUserRole('logistician') || hasCurrentUserRole('cargo_owner');
    }

    function ownProfileUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'username',
        'usernameLower',
        'name',
        'aboutMe',
        'avatarUrl',
        'photoURL',
        'photoUrl',
        'avatarUpdatedAt',
        'car',
        'fcmToken',
        'updatedAt',
        'emailCodeVerified'
      ]);
    }

    function profileMirrorWrite() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'uid',
        'email',
        'role',
        'roles',
        'username',
        'usernameLower',
        'name',
        'aboutMe',
        'avatarUrl',
        'photoURL',
        'photoUrl',
        'avatarUpdatedAt',
        'car',
        'fcmToken',
        'updatedAt',
        'emailCodeVerified'
      ]);
    }

    function ratingAggregateUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'ratingCount',
        'ratingSum'
      ]);
    }

    function isCargoParticipant() {
      return signedIn()
        && (resource.data.ownerId == request.auth.uid
          || resource.data.driverId == request.auth.uid
          || (resource.data.executorId != null && resource.data.executorId == request.auth.uid));
    }

    match /adminAccounts/{uid} {
      allow read: if isSelf(uid) || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /users/{uid} {
      allow read: if signedIn() || isAdmin();
      allow create: if isSelf(uid)
        && request.resource.data.uid == uid
        && request.resource.data.role in [
          'carrier', 'logistician', 'cargo_owner', 'forwarder',
          'lawyer',
          'carrier_forwarder', 'cargo_owner_carrier', 'logistician_carrier',
          'driver', 'driver_forwarder', 'driver_cargo_owner'
        ];
      allow update: if isAdmin()
        || (isSelf(uid) && ownProfileUpdate())
        || (signedIn() && ratingAggregateUpdate());
      allow delete: if isAdmin();

      match /favoriteCargos/{cargoId} {
        allow read, write: if isSelf(uid) || isAdmin();
      }

      match /ratings/{raterId} {
        allow read: if signedIn();
        allow create, update: if isSelf(raterId)
          && request.resource.data.raterId == request.auth.uid
          && request.resource.data.score >= 1
          && request.resource.data.score <= 5;
        allow delete: if isAdmin();
      }

      match /notifications/{notificationId} {
        allow read, update, delete: if isSelf(uid) || isAdmin();
        allow create: if signedIn();
      }
    }

    match /drivers/{uid} {
      allow read: if signedIn();
      allow create: if isSelf(uid)
        && request.resource.data.uid == uid
        && (request.resource.data.role in [
          'carrier', 'driver', 'carrier_forwarder', 'driver_forwarder',
          'cargo_owner_carrier', 'driver_cargo_owner', 'logistician_carrier'
        ]);
      allow update: if isAdmin()
        || (isSelf(uid) && profileMirrorWrite())
        || (signedIn() && ratingAggregateUpdate());
      allow delete: if isAdmin();
    }

    match /logisticians/{uid} {
      allow read: if signedIn();
      allow create: if isSelf(uid)
        && request.resource.data.uid == uid
        && (request.resource.data.role in [
          'logistician', 'cargo_owner', 'forwarder',
          'cargo_owner_carrier', 'logistician_carrier'
        ]);
      allow update: if isAdmin()
        || (isSelf(uid) && profileMirrorWrite())
        || (signedIn() && ratingAggregateUpdate());
      allow delete: if isAdmin();
    }

    match /usernames/{username} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /cargos/{cargoId} {
      allow read: if true;
      allow create: if signedIn()
        && (request.resource.data.ownerId == request.auth.uid || isLogistician() || isAdmin());
      allow update: if isAdmin() || isLogistician() || isCargoParticipant();
      allow delete: if isAdmin()
        || (signedIn() && resource.data.ownerId == request.auth.uid);

      match /messages/{messageId} {
        allow read, create: if signedIn();
        allow update, delete: if isAdmin()
          || (signedIn() && resource.data.senderId == request.auth.uid);
      }
    }

    match /cargoApplications/{applicationId} {
      allow read: if isAdmin()
        || (signedIn()
          && (resource.data.ownerId == request.auth.uid
            || resource.data.applicantId == request.auth.uid
            || isLogistician()));
      allow create: if signedIn()
        && request.resource.data.applicantId == request.auth.uid
        && request.resource.data.ownerId != request.auth.uid;
      allow update: if isAdmin() || isLogistician()
        || (signedIn() && (resource.data.ownerId == request.auth.uid || resource.data.applicantId == request.auth.uid));
      allow delete: if isAdmin() || (signedIn() && resource.data.applicantId == request.auth.uid);
    }

    match /siteNotifications/{notificationId} {
      allow read: if isAdmin()
        || (signedIn() && resource.data.userId == request.auth.uid);
      allow create, update: if signedIn();
      allow delete: if isAdmin()
        || (signedIn() && resource.data.userId == request.auth.uid);
    }

    match /activityLogs/{activityId} {
      allow read: if isAdmin()
        || (signedIn() && request.auth.uid in resource.data.visibleTo);
      allow create: if signedIn();
      allow update, delete: if isAdmin();
    }

    match /cargoDocuments/{documentId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.uploadedBy == request.auth.uid;
      allow update, delete: if isAdmin()
        || (signedIn() && resource.data.uploadedBy == request.auth.uid);
    }

    match /userReports/{reportId} {
      allow create: if signedIn()
        && request.resource.data.reporterId == request.auth.uid;
      allow read, update, delete: if isAdmin();
    }

    match /conversations/{conversationId} {
      allow read: if isAdmin()
        || (signedIn() && (request.auth.uid in resource.data.participants || request.auth.uid in conversationId.split('_')));
      allow create: if signedIn()
        && request.resource.data.participants is list
        && request.auth.uid in request.resource.data.participants;
      allow update: if signedIn()
        && (request.auth.uid in resource.data.participants || request.auth.uid in conversationId.split('_'));
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if signedIn() && (isAdmin() || request.auth.uid in conversationId.split('_'));
        allow create: if signedIn() && (isAdmin() || request.auth.uid in conversationId.split('_'));
        allow update, delete: if isAdmin()
          || (signedIn() && resource.data.senderId == request.auth.uid);
      }
    }

    match /clients/{document=**} {
      allow read, write: if signedIn();
    }

    match /documents/{document=**} {
      allow read, write: if signedIn();
    }

    match /delivery_reports/{document=**} {
      allow read, write: if signedIn();
    }

    match /cargo_tracking/{document=**} {
      allow read, write: if signedIn();
    }

    // ── OTP Codes ───────────────────────────────────────────────────────────
    match /emailOtpCodes/{uid} {
      allow read, write: if isSelf(uid);
    }

    // ── Tenders ─────────────────────────────────────────────────────────────
    match /tenders/{tenderId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && (isLogistician() || isAdmin());
      allow update: if isAdmin()
        || isLogistician()
        || (signedIn() && resource.data.ownerId == request.auth.uid);
      allow delete: if isAdmin()
        || (signedIn() && resource.data.ownerId == request.auth.uid);

      match /bids/{bidId} {
        allow read: if signedIn();
        allow create: if signedIn()
          && request.resource.data.bidderId == request.auth.uid
          && resource == null;
        allow update: if signedIn()
          && (resource.data.bidderId == request.auth.uid
            || get(/databases/$(database)/documents/tenders/$(tenderId)).data.ownerId == request.auth.uid);
        allow delete: if isAdmin();
      }
    }
    match /transports/{transportId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isAdmin() || (signedIn() && resource.data.ownerId == request.auth.uid);
      allow delete: if isAdmin() || (signedIn() && resource.data.ownerId == request.auth.uid);
    }

    match /companyProfiles/{uid} {
      allow read: if isAdmin() || isSelf(uid);
      allow create, update: if isSelf(uid);
      allow delete: if isAdmin() || isSelf(uid);
    }

    match /serviceRequests/{requestId} {
      allow read: if isAdmin()
        || (signedIn() && (resource.data.userId == request.auth.uid || isLogistician()))
        || (hasCurrentUserRole('lawyer') && resource.data.type == 'legal');
      allow create: if signedIn();
      allow update: if isAdmin()
        || (signedIn() && resource.data.userId == request.auth.uid)
        || (hasCurrentUserRole('lawyer') && resource.data.type == 'legal');
      allow delete: if isAdmin()
        || (signedIn() && resource.data.userId == request.auth.uid);
    }
  }
}
